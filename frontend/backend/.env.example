# MongoDB connection
# Local MongoDB with username/password auth (as requested: ak / ak@123)
MONGO_URI=mongodb://ak:ak%40123@localhost:27017/xceed_india?authSource=admin

# Alternative: MongoDB Atlas example
# MONGO_URI=mongodb+srv://ak:ak%40123@cluster0.mongodb.net/xceed_india

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=xceed_india_super_secret_change_me
JWT_EXPIRES_IN=7d

# Default admin (created by seed script)
ADMIN_USERNAME=ak
ADMIN_PASSWORD=ak@123
ADMIN_EMAIL=admin@xceedindia.com

# CORS
CLIENT_URL=http://localhost:3000

# SMTP (for emailing quotations from the Bulk Quote CRM)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=sales@xceedonetouch.com

# Anthropic (for AI-generated product descriptions in the admin panel)
ANTHROPIC_API_KEY=
